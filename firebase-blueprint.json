{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the authenticated user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth ID." },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "CareerAnalysis": {
      "title": "Career Analysis",
      "description": "A saved career analysis result for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns this analysis." },
        "profile": {
          "type": "object",
          "properties": {
            "skills": { "type": "string" },
            "interests": { "type": "string" },
            "education": { "type": "string" },
            "experience": { "type": "string" }
          }
        },
        "suggestions": {
          "type": "array",
          "items": { "$ref": "CareerSuggestion" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "profile", "suggestions", "createdAt"]
    },
    "CareerSuggestion": {
      "title": "Career Suggestion",
      "description": "A single career path suggestion.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "matchScore": { "type": "number" },
        "why": { "type": "string" },
        "jobRoles": { "type": "array", "items": { "type": "string" } },
        "courses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "provider": { "type": "string" },
              "link": { "type": "string" }
            }
          }
        },
        "roadmap": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "step": { "type": "number" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "duration": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/users/{userId}/analyses/{analysisId}": {
      "schema": "CareerAnalysis",
      "description": "Career analysis results for a specific user."
    }
  }
}
